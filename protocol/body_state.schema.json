{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-body-runtime/body_state.schema.json",
  "title": "BodyStateResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ok", "state", "screenshot_path", "errors"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pose",
        "body_mode",
        "action",
        "action_source",
        "animation_name",
        "animation_length",
        "animation_wait_time",
        "available_animations",
        "expression",
        "holding",
        "attached_prop",
        "target_socket",
        "attachments",
        "gaze",
        "camera",
        "is_busy",
        "last_action_status"
      ],
      "properties": {
        "pose": {
          "type": "string",
          "enum": ["idle", "standing", "sitting", "waving", "holding_cup", "looking_at_user", "attaching_prop", "unknown"]
        },
        "body_mode": {
          "type": "string",
          "enum": ["placeholder", "real_model"]
        },
        "action": {
          "type": "string",
          "enum": ["idle", "look_at_user", "wave", "sit_chair", "stand_up", "hold_cup", "attach_prop", "run", "jump", "interact"]
        },
        "action_source": {
          "type": "string",
          "enum": ["placeholder_transform", "animation", "profile_fallback", "programmatic"]
        },
        "animation_name": {
          "type": "string",
          "minLength": 1
        },
        "animation_length": {
          "type": "number",
          "minimum": 0
        },
        "animation_wait_time": {
          "type": "number",
          "minimum": 0
        },
        "available_animations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expression": {
          "type": "string",
          "enum": ["neutral", "smile", "surprised"]
        },
        "holding": {
          "type": "string",
          "enum": ["none", "cup"]
        },
        "attached_prop": {
          "type": "string",
          "enum": ["none", "cup", "bucket"]
        },
        "target_socket": {
          "type": "string",
          "enum": ["none", "right_hand", "left_hand", "head", "back", "waist"]
        },
        "attachments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["right_hand", "left_hand", "head", "back", "waist"],
          "properties": {
            "right_hand": {
              "type": "string",
              "enum": ["none", "cup", "bucket"]
            },
            "left_hand": {
              "type": "string",
              "enum": ["none", "cup", "bucket"]
            },
            "head": {
              "type": "string",
              "enum": ["none", "cup", "bucket"]
            },
            "back": {
              "type": "string",
              "enum": ["none", "cup", "bucket"]
            },
            "waist": {
              "type": "string",
              "enum": ["none", "cup", "bucket"]
            }
          }
        },
        "gaze": {
          "type": "string",
          "enum": ["none", "user"]
        },
        "camera": {
          "type": "string",
          "enum": ["front_medium", "front_full", "close_face"]
        },
        "is_busy": {
          "type": "boolean"
        },
        "last_action_status": {
          "type": "string",
          "enum": ["success", "busy", "invalid_intent", "error"]
        }
      }
    },
    "screenshot_path": {
      "type": "string"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
