{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-body-runtime/body_state.schema.json",
  "title": "BodyStateResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ok", "state", "screenshot_path", "errors"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pose",
        "action",
        "expression",
        "holding",
        "gaze",
        "camera",
        "is_busy",
        "last_action_status"
      ],
      "properties": {
        "pose": {
          "type": "string",
          "enum": ["idle", "standing", "sitting", "waving", "holding_cup", "looking_at_user", "unknown"]
        },
        "action": {
          "type": "string",
          "enum": ["idle", "look_at_user", "wave", "sit_chair", "stand_up", "hold_cup"]
        },
        "expression": {
          "type": "string",
          "enum": ["neutral", "smile", "surprised"]
        },
        "holding": {
          "type": "string",
          "enum": ["none", "cup"]
        },
        "gaze": {
          "type": "string",
          "enum": ["none", "user"]
        },
        "camera": {
          "type": "string",
          "enum": ["front_medium", "front_full", "close_face"]
        },
        "is_busy": {
          "type": "boolean"
        },
        "last_action_status": {
          "type": "string",
          "enum": ["success", "busy", "invalid_intent", "error"]
        }
      }
    },
    "screenshot_path": {
      "type": "string"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

